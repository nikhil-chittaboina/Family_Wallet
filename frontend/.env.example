# Backend API URL (no trailing slash).
# Leave empty for local dev — Vite proxies /api to localhost:5000.
# Set when building for production, e.g. https://your-api.onrender.com
VITE_API_URL=

# Display name shown in sidebar and dashboard greeting
VITE_USER_NAME=Nik

# Currency formatting (ISO 4217 code + BCP 47 locale)
VITE_CURRENCY=INR
VITE_LOCALE=en-IN
