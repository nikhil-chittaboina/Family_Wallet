# Server port (platforms like Render/Railway set PORT automatically)
PORT=5000

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/family-expense-tracker

# Allowed frontend origin(s) for CORS — comma-separated for multiple
# Example: https://your-app.netlify.app,https://www.yourdomain.com
CLIENT_URL=http://localhost:3000
