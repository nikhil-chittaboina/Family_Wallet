# Server port (platforms like Render/Railway set PORT automatically)
PORT=5000

# MongoDB connection string
# Option A — SRV (works on most cloud hosts):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/family-expense-tracker?retryWrites=true&w=majority
#
# Option B — Standard URI (use if mongodb+srv fails locally with querySrv ECONNREFUSED):
# Get hostnames from Atlas → Connect → Drivers → "Connection string only" → toggle off SRV
# MONGO_URI=mongodb://<username>:<password>@host1:27017,host2:27017,host3:27017/family-expense-tracker?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin&retryWrites=true&w=majority

MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/family-expense-tracker?retryWrites=true&w=majority

# Allowed frontend origin(s) for CORS — comma-separated
# Example: http://localhost:3000,https://family-wallet.netlify.app
CLIENT_URL=http://localhost:3000,https://family-wallet.netlify.app
